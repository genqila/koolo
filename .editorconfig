root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[{*.go,go.{mod,work,work.sum,sum}}]
indent_style = tab
indent_size = 2
tab_width = 2

[*.md]
trim_trailing_whitespace = false

[*.bat]
end_of_line = crlf
